rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. DEFAULT DENY ALL CATCH-ALL
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES ---
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- SECURITY RULE ENTITY VALIDATIONS ---

    function isValidTenant(data) {
      return data.id is string && data.id.size() <= 128
        && data.business_name is string && data.business_name.size() <= 200
        && data.slug is string && data.slug.size() <= 100
        && data.owner_email is string && data.owner_email.size() <= 150
        && data.primary_color is string && data.primary_color.size() <= 30
        && data.currency is string && data.currency.size() <= 10
        && data.currency_symbol is string && data.currency_symbol.size() <= 10;
    }

    function isValidVehicle(data) {
      return data.id is string && data.id.size() <= 128
        && data.tenant_id is string && data.tenant_id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.model is string && data.model.size() <= 100
        && data.category is string && data.category.size() <= 50
        && data.max_passengers is number && data.max_passengers >= 1
        && data.rate_per_km is number && data.rate_per_km >= 0
        && data.is_active is bool;
    }

    function isValidDriver(data) {
      return data.id is string && data.id.size() <= 128
        && data.tenant_id is string && data.tenant_id.size() <= 128
        && data.full_name is string && data.full_name.size() <= 200
        && data.email is string && data.email.size() <= 150
        && data.phone is string && data.phone.size() <= 50
        && data.status is string && data.status.size() <= 50;
    }

    function isValidBooking(data) {
      return data.id is string && data.id.size() <= 128
        && data.tenant_id is string && data.tenant_id.size() <= 128
        && data.tenant_slug is string && data.tenant_slug.size() <= 100
        && data.booking_ref is string && data.booking_ref.size() <= 128
        && data.status is string && data.status.size() <= 50
        && data.booking_type is string && data.booking_type.size() <= 50
        && data.pickup_address is string && data.pickup_address.size() <= 500
        && data.dropoff_address is string && data.dropoff_address.size() <= 500
        && data.pickup_date is string && data.pickup_date.size() <= 50
        && data.pickup_time is string && data.pickup_time.size() <= 50
        && data.passenger_name is string && data.passenger_name.size() <= 200
        && data.passenger_email is string && data.passenger_email.size() <= 150
        && data.total_fare is number && data.total_fare >= 0
        && data.payment_method is string && data.payment_method.size() <= 50
        && data.payment_status is string && data.payment_status.size() <= 50;
    }

    function isValidRoute(data) {
      return data.id is string && data.id.size() <= 128
        && data.tenant_id is string && data.tenant_id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.pickup_area is string && data.pickup_area.size() <= 250
        && data.dropoff_area is string && data.dropoff_area.size() <= 250
        && data.flat_rate is number && data.flat_rate >= 0
        && data.is_active is bool;
    }

    function isValidPromo(data) {
      return data.id is string && data.id.size() <= 128
        && data.tenant_id is string && data.tenant_id.size() <= 128
        && data.code is string && data.code.size() <= 50
        && data.discount_type is string && data.discount_type.size() <= 30
        && data.discount_value is number && data.discount_value >= 0
        && data.is_active is bool;
    }

    function isValidLocation(data) {
      return data.id is string && data.id.size() <= 128
        && data.driver_id is string && data.driver_id.size() <= 128
        && data.lat is number
        && data.lng is number
        && data.is_active is bool;
    }

    function isValidReview(data) {
      return data.id is string && data.id.size() <= 128
        && data.tenant_id is string && data.tenant_id.size() <= 128
        && data.booking_id is string && data.booking_id.size() <= 128
        && data.booking_ref is string && data.booking_ref.size() <= 128
        && data.rating is number && data.rating >= 1 && data.rating <= 5;
    }

    // --- COLLECTION GATES ---

    // A. Tenants Rules
    match /tenants/{tenantId} {
      allow read: if true; // Publicly readable for dynamic whitelabel customization configs lookups
      allow get: if isValidId(tenantId);
      allow create, update: if isValidTenant(incoming()) && (
        !isSignedIn() || request.auth.token.email_verified == true
      ); // Anyone can create a new tenant block during deployment, or verified super admins
      allow delete: if isSignedIn() && request.auth.token.email_verified == true;
    }

    // B. Vehicles Rules
    match /vehicles/{vehicleId} {
      allow read: if true; // Publicly readable for booking forms vehicle selection lists
      allow get: if isValidId(vehicleId);
      allow write: if isValidVehicle(incoming()); // Tenant admin/owner configuration write
    }

    // C. Drivers Rules
    match /drivers/{driverId} {
      allow read: if true; // Publicly readable for assignment lookup mapping display cards
      allow get: if isValidId(driverId);
      allow write: if isValidDriver(incoming());
    }

    // D. Bookings Rules
    match /bookings/{bookingId} {
      allow read: if true; // Publicly searchable for status lookups from reference codes, secure matching occurs in component filtering
      allow get: if isValidId(bookingId);
      allow create: if isValidBooking(incoming()); // Guests booking from Whitelabel portals
      allow update: if isValidBooking(incoming()); // Drivers updating route statuses / admin dispatches
      allow delete: if isSignedIn();
    }

    // E. Routes Rules
    match /routes/{routeId} {
      allow read: if true; // Public options
      allow get: if isValidId(routeId);
      allow write: if isValidRoute(incoming());
    }

    // F. Promos Rules
    match /promos/{promoId} {
      allow read: if true; // Public promotion applications
      allow get: if isValidId(promoId);
      allow write: if isValidPromo(incoming());
    }

    // G. Locations Rules
    match /locations/{locationId} {
      allow read: if true; // Live dynamic passenger view tracking feeds
      allow get: if isValidId(locationId);
      allow write: if isValidLocation(incoming());
    }

    // H. Reviews Rules
    match /reviews/{reviewId} {
      allow read: if true; // Corporate review lists public feedback displays
      allow get: if isValidId(reviewId);
      allow write: if isValidReview(incoming());
    }
  }
}

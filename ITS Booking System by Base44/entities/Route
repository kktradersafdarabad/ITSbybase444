{
  "name": "Route",
  "type": "object",
  "properties": {
    "tenant_id": {
      "type": "string",
      "description": "Tenant this route belongs to"
    },
    "name": {
      "type": "string",
      "description": "Route name e.g. Airport Transfer"
    },
    "pickup_area": {
      "type": "string",
      "description": "Pickup area/location"
    },
    "dropoff_area": {
      "type": "string",
      "description": "Dropoff area/location"
    },
    "distance_km": {
      "type": "number",
      "description": "Fixed distance in KM"
    },
    "flat_rate": {
      "type": "number",
      "description": "Flat rate price"
    },
    "is_active": {
      "type": "boolean",
      "description": "Whether route is active"
    },
    "description": {
      "type": "string",
      "description": "Route description"
    }
  },
  "required": [
    "name",
    "pickup_area",
    "dropoff_area",
    "flat_rate"
  ]
}
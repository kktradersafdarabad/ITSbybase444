{
  "name": "CompanySettings",
  "type": "object",
  "properties": {
    "company_name": {
      "type": "string",
      "description": "Company name"
    },
    "logo_url": {
      "type": "string",
      "description": "Company logo URL"
    },
    "primary_color": {
      "type": "string",
      "description": "Brand primary color hex"
    },
    "currency": {
      "type": "string",
      "description": "Currency code e.g. USD"
    },
    "currency_symbol": {
      "type": "string",
      "description": "Currency symbol e.g. $"
    },
    "base_fare": {
      "type": "number",
      "description": "Default base fare"
    },
    "cost_per_km": {
      "type": "number",
      "description": "Default cost per KM"
    },
    "cost_per_minute": {
      "type": "number",
      "description": "Default cost per minute"
    },
    "hourly_rate": {
      "type": "number",
      "description": "Default hourly rate"
    },
    "surge_multiplier": {
      "type": "number",
      "description": "Surge pricing multiplier"
    },
    "surge_start_hour": {
      "type": "number",
      "description": "Surge start hour (24h)"
    },
    "surge_end_hour": {
      "type": "number",
      "description": "Surge end hour (24h)"
    },
    "contact_email": {
      "type": "string",
      "description": "Contact email"
    },
    "contact_phone": {
      "type": "string",
      "description": "Contact phone"
    },
    "timezone": {
      "type": "string",
      "description": "Business timezone"
    },
    "border_radius": {
      "type": "string",
      "description": "UI border radius style"
    },
    "language": {
      "type": "string",
      "enum": [
        "en",
        "ur",
        "ar",
        "es",
        "fr"
      ],
      "description": "Default language"
    },
    "stripe_publishable_key": {
      "type": "string",
      "description": "Stripe publishable key"
    },
    "stripe_secret_key": {
      "type": "string",
      "description": "Stripe secret key"
    },
    "paypal_client_id": {
      "type": "string",
      "description": "PayPal client ID"
    },
    "paypal_secret": {
      "type": "string",
      "description": "PayPal secret"
    },
    "form_config": {
      "type": "object",
      "description": "Booking form builder config"
    }
  },
  "required": [
    "company_name"
  ]
}